PUBLIC_MIXPANEL_TOKEN=

# Resend (https://resend.com) — create an API key and verify your domain.
# Copy to `.env` for local dev. Set the same variables in Netlify (Site settings → Environment variables).
RESEND_API_KEY=

# Verified sender, e.g. "Orkesto Contact <hello@orkesto.se>"
# Until your domain is verified in Resend, you can use their onboarding address:
# RESEND_FROM_EMAIL=Orkesto Contact <onboarding@resend.dev>
RESEND_FROM_EMAIL=
